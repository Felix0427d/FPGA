#project files
add_file -constraint "C:/lscc/radiant/2025.2/scripts/tcl/flow/radiant_synplify_vars.tcl"
add_file -constraint "C:/Users/felix/Documents/Master_1ECAM/FPGA/lab/lab3.sdc"
add_file -verilog "C:/lscc/radiant/2025.2/ip/pmi/pmi_iCE40UP.v"
add_file -vhdl -lib pmi "C:/lscc/radiant/2025.2/ip/pmi/pmi_iCE40UP.vhd"
add_file -vhdl -lib work "C:/Users/felix/Documents/Master_1ECAM/FPGA/lab3_files/led.vhd"
add_file -vhdl -lib work "C:/lscc/radiant/2025.2/cae_library/synthesis/vhdl/iCE40UP.vhd"


#implementation: "lab_1"
impl -add C:\Users\felix\Documents\Master_1ECAM\FPGA\lab\lab_1 -type fpga

#
#implementation attributes

set_option -vlog_std v2001
set_option -project_relative_includes 1
set_option -include_path {C:/Users/felix/Documents/Master_1ECAM/FPGA/lab/lab_1/}

#device options
set_option -technology SBTICE40UP
set_option -part iCE40UP5K
set_option -package SG48I
set_option -speed_grade -6

#compilation/mapping options
set_option -top_module "work.led"

# hdl_compiler_options
set_option -hdl_strict_syntax 0

# mapper_without_write_options
set_option -frequency 200
set_option -srs_instrumentation 1

# mapper_options
set_option -write_verilog 0
set_option -write_structural_verilog 0
set_option -write_vhdl 0
set_option -design_rule_fanout_limit 0

# Lattice iCE40UP
set_option -lattice_software Radiant
set_option -const_mult_threshold 2
set_option -maxfan 1000
set_option -rw_check_on_ram 0
set_option -disable_io_insertion 0
set_option -pipe 1
set_option -infer_seqShift 1
set_option -retiming 0
set_option -update_models_cp 0
set_option -fix_gated_and_generated_clocks 0
set_option -run_prop_extract 1
set_option -seqshift_no_replicate 0
set_option -run_design_rule_checker 0

# NFilter
set_option -no_sequential_opt 0

# sequential_optimization_options
set_option -symbolic_fsm_compiler 1

# Compiler Options
set_option -compiler_compatible 0
set_option -resource_sharing 1
set_option -multi_file_compilation_unit 1

#automatic place and route (vendor) options
set_option -write_apr_constraint 1

#set result format/file last
project -result_file "C:/Users/felix/Documents/Master_1ECAM/FPGA/lab/lab_1/lab_lab_1.vm"

#set log file 
set_option log_file "C:/Users/felix/Documents/Master_1ECAM/FPGA/lab/lab_1/lab_lab_1.srf" 
impl -active "lab_1"
